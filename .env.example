LOCAL_MODE=true
ENV=development
APP_NAME=prithvi-ai
API_VERSION=v1

HOST=0.0.0.0
PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./prithvi.db
REDIS_URL=memory://local

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

SECRET_KEY=change_me_dev_secret
JWT_ISSUER=prithvi-ai
JWT_AUDIENCE=prithvi-clients
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# Cookies
COOKIE_SECURE=false

# Step 2 additions
CACHE_TTL_SECONDS=300
ERA5_SOURCE=local
GHO_SOURCE=local
POP_SOURCE=local
PILOT_REGION_CODE=PILOT1
TILES_PATH=./tiles
